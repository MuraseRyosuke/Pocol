# ==========================================
# Pocol .gitignore
# ==========================================

# --- 1. Environment Variables & Secrets (CRITICAL) ---
# ※APIキーやトークンが含まれるため、絶対に公開・コミットしてはいけません
.env
.env.*

# --- 2. Database & Backups ---
# ※会話履歴や学習データ（個人情報）が含まれるため除外します
*.db
*.sqlite
*.sqlite3
pocol*.db

# --- 3. Virtual Environments ---
# ※仮想環境フォルダ（uv / venv）
.venv/
venv/
env/

# --- 4. Python General ---
__pycache__/
*.py[cod]
*$py.class

# --- 5. Logs & Temporary Files ---
*.log
*.tmp

# --- 6. IDE / Editor Settings ---
# ※エディタの個人設定ファイル
.vscode/
.idea/

# --- 7. Operating System Files ---
# Mac
.DS_Store
# Windows
Thumbs.db
Desktop.ini
ehthumbs.db

# --- 8. Caches (Future Proofing) ---
.pytest_cache/
.ruff_cache/
.mypy_cache/