# --- Python General ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual Environments (uv / venv) ---
# 仮想環境フォルダは絶対にアップロードしない
.venv/
venv/
env/

# --- Environment Variables (CRITICAL) ---
# APIキーが含まれるため、絶対に公開してはいけません
.env
.env.*

# --- Database (SQLite) ---
# 会話履歴（個人情報）が含まれるため除外します
*.db
*.sqlite
*.sqlite3
pocol.db

# --- Logs & Temporary Files ---
*.log
*.tmp

# --- IDE / Editor Settings ---
# エディタの個人設定ファイル
.vscode/
.idea/

# --- Operating System Files ---
# Mac
.DS_Store
# Windows
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Cache (Future Proofing) ---
# 将来テストや整形ツールを入れた時用
.pytest_cache/
.ruff_cache/
.mypy_cache/